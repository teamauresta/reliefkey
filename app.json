{
  "expo": {
    "owner": "yang_yan",
    "name": "ReliefKey",
    "slug": "reliefkey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reliefkey.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ReliefKey uses your location to find nearby restrooms.",
        "NSLocationAlwaysUsageDescription": "ReliefKey uses your location to find nearby restrooms."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyD1BFoVYQsJ2OTxmTOz9Z5PCkkeAZ6Kn8w"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.reliefkey.app",
      "minSdkVersion": 21,
      "targetSdkVersion": 34,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD1BFoVYQsJ2OTxmTOz9Z5PCkkeAZ6Kn8w"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ReliefKey uses your location to find nearby restrooms."
        }
      ]
    ]
  }
}
